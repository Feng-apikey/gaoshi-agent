{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": false,
    "baseUrl": ".",
    "paths": { "@/*": ["./*"] }
  },
  "include": ["api/**/*.ts", "agent/**/*.ts", "schemas/**/*.ts", "storage/**/*.ts", "formatters/**/*.ts", "browser/**/*.ts"]
}
