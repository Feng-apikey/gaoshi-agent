{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": false,
    "baseUrl": ".",
    "paths": { "@/*": ["./*"] },
    "allowImportingTsExtensions": true,
    "ignoreDeprecations": "6.0"
  },
  "include": ["api/**/*.ts", "agent/**/*.ts", "publish/**/*.ts", "tools/**/*.ts", "mcp/**/*.ts", "schemas/**/*.ts", "storage/**/*.ts", "formatters/**/*.ts"]
}
