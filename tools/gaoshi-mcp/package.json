{
  "name": "gaoshi-mcp",
  "version": "0.1.0",
  "description": "稿事应用层 MCP — drafts / files / render / system",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "esbuild server.ts --bundle --platform=node --target=es2022 --format=esm --outfile=dist/server.js --external:better-sqlite3 --external:playwright --external:playwright-core",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.0",
    "better-sqlite3": "^12.10.0",
    "drizzle-orm": "^0.36.0",
    "playwright": "^1.49.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
