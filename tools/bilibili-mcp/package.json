{
  "name": "bilibili-mcp",
  "version": "0.2.0",
  "description": "B站创作者平台 MCP Server — 浏览器自动化：动态/视频/专栏发布、搜索",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "bilibili-mcp": "dist/server.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx server.ts",
    "build": "esbuild server.ts --bundle --platform=node --target=es2022 --format=esm --outfile=dist/server.js --external:playwright --external:playwright-core",
    "start": "node dist/server.js",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.0",
    "playwright": "^1.49.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "keywords": ["mcp", "bilibili", "B站", "creator", "automation"],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  }
}
